{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inkshader.dev/schemas/project_schema.json",
  "title": "InkShader Project File",
  "description": "Save format for InkShader font editor — flat top-level fields, groups by name, paths/components as children array, vertices as array with implicit indexing",
  "type": "object",
  "required": [
    "version",
    "family_name",
    "basic_spacing",
    "editor_sequence",
    "editor_active_indices",
    "editor_guidelines",
    "editor_guideline_lock",
    "editor_root_order",
    "glyphs"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "File format version (semantic major.minor)",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["1.0"]
    },
    "family_name": {
      "type": "string",
      "description": "Font family name"
    },
    "project_name": {
      "type": "string",
      "description": "Project name (reserved, currently empty on export)"
    },
    "font_style": {
      "type": "string",
      "description": "Font style/subfamily name"
    },
    "postscript_name": {
      "type": "string",
      "description": "PostScript font name"
    },
    "preferred_family": {
      "type": "string",
      "description": "Preferred family name"
    },
    "preferred_subfamily": {
      "type": "string",
      "description": "Preferred subfamily name"
    },
    "copyright": {
      "type": "string",
      "description": "Font copyright text"
    },
    "designer": {
      "type": "string",
      "description": "Font designer"
    },
    "designer_url": {
      "type": "string",
      "description": "Designer URL"
    },
    "manufacturer": {
      "type": "string",
      "description": "Font manufacturer"
    },
    "manufacturer_url": {
      "type": "string",
      "description": "Manufacturer URL"
    },
    "license": {
      "type": "string",
      "description": "Font license text"
    },
    "license_url": {
      "type": "string",
      "description": "License URL"
    },
    "trademark": {
      "type": "string",
      "description": "Font trademark text"
    },
    "description": {
      "type": "string",
      "description": "Font description"
    },
    "sample_text": {
      "type": "string",
      "description": "Font sample text"
    },
    "upm": {
      "type": "number",
      "description": "Units per em",
      "minimum": 16,
      "maximum": 16384
    },
    "weight_class": {
      "type": "number",
      "description": "OS/2 weight class",
      "minimum": 1,
      "maximum": 1000
    },
    "width_class": {
      "type": "number",
      "description": "OS/2 width class",
      "minimum": 1,
      "maximum": 9
    },
    "ascender": {
      "type": "number",
      "description": "Font ascender"
    },
    "descender": {
      "type": "number",
      "description": "Font descender"
    },
    "x_height": {
      "type": "number",
      "description": "Font x-height"
    },
    "cap_height": {
      "type": "number",
      "description": "Font cap height"
    },
    "font_version": {
      "type": "string",
      "description": "Font version string"
    },
    "basic_spacing": {
      "type": "number",
      "description": "Default advance width for glyphs without explicit advance",
      "default": 1000
    },
    "editor_sequence": {
      "type": "string",
      "description": "Glyph sequence text with \\group\\ references"
    },
    "editor_active_indices": {
      "type": "array",
      "description": "Currently active sequence indices (multi-selection)",
      "items": { "type": "number", "minimum": 0 }
    },
    "editor_guidelines": {
      "type": "array",
      "description": "All guidelines (ruler-dragged and user-defined), each defined by a point and angle in degrees. angle=0 is horizontal, angle=90 is vertical.",
      "items": { "$ref": "#/$defs/GuidelineData" }
    },
    "editor_guideline_lock": {
      "type": "boolean",
      "description": "Whether guidelines are locked against editing",
      "default": false
    },
    "editor_root_order": {
      "type": "array",
      "description": "Root-level group display order (group names)",
      "items": { "type": "string" }
    },
    "glyphs": {
      "type": "object",
      "description": "All glyph-like groups indexed by group name — names are unique identifiers",
      "propertyNames": { "type": "string" },
      "additionalProperties": { "$ref": "#/$defs/GroupData" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "GuidelineData": {
      "type": "object",
      "description": "A guideline defined by a through-point and angle in degrees. Rendered as a line extending to canvas bounds.",
      "required": ["id", "x", "y", "angle"],
      "properties": {
        "id": { "type": "integer", "description": "Unique guideline identifier" },
        "x": { "type": "number", "description": "X position (through-point)" },
        "y": { "type": "number", "description": "Y position (through-point)" },
        "angle": { "type": "integer", "description": "Angle in degrees (0=horizontal, 90=vertical)", "default": 0 }
      },
      "additionalProperties": false
    },
    "GroupData": {
      "type": "object",
      "description": "A group (glyph / component definition / folder) with nested children (paths and component refs)",
      "properties": {
        "name": { "type": "string", "description": "Group display name" },
        "char_code": { "type": ["string", "null"], "description": "Single character mapped to this glyph, or null for non-glyph groups" },
        "advance": { "type": "number", "description": "Advance width in UPM units", "default": 1000, "minimum": 0 },
        "locked": { "type": "boolean", "description": "Whether the group is locked against editing", "default": false },
        "visible": { "type": "boolean", "description": "Whether the group is visible", "default": true },
        "template": { "type": "boolean", "description": "Whether this is a template component (reusable by reference)", "default": false },
        "children": {
          "type": "array",
          "description": "Ordered list of child items — paths and component references",
          "items": { "$ref": "#/$defs/ChildItem" }
        }
      },
      "additionalProperties": false
    },
    "ChildItem": {
      "type": "object",
      "description": "A child of a group — either a Bezier path or a component reference (distinguished by the 'type' field)",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Item type discriminator",
          "enum": ["path", "component"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "path" } }
          },
          "then": {
            "required": ["name", "vertices"],
            "properties": {
              "name": { "type": "string", "description": "Path name (unique within the group)" },
              "closed": { "type": "boolean", "description": "Whether the path is closed", "default": false },
              "stroke_width": { "type": "number", "description": "Stroke width in UPM units", "default": 8, "minimum": 0 },
              "smart_stroke": { "type": "boolean", "description": "Whether smart expand stroke is enabled", "default": false },
              "smart_stroke_clockwise": { "type": "boolean", "description": "Smart stroke winding direction", "default": false },
              "show_skeleton": { "type": "boolean", "description": "Whether skeleton lines are shown in editor", "default": false },
              "visible": { "type": "boolean", "description": "Whether the path is visible", "default": true },
              "locked": { "type": "boolean", "description": "Whether editing this path is locked", "default": false },
              "vertices": {
                "type": "array",
                "description": "Ordered vertices (array index = traversal order)",
                "items": { "$ref": "#/$defs/VertexData" }
              }
            },
            "additionalProperties": false
          },
          "else": {
            "required": ["component_id", "transform"],
            "properties": {
              "component_id": { "type": "string", "description": "Target component group name" },
              "transform": {
                "type": "array",
                "description": "Affine transform matrix [a, b, c, d, tx, ty] (row-major 2x3)",
                "items": { "type": "number" },
                "minItems": 6,
                "maxItems": 6
              },
              "visible": { "type": "boolean", "description": "Whether the component reference is visible", "default": true },
              "locked": { "type": "boolean", "description": "Whether the component reference is locked", "default": false }
            },
            "additionalProperties": false
          }
        }
      ]
    },
    "VertexData": {
      "type": "object",
      "description": "A single vertex (node) on a Bezier path — array index defines traversal order",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "description": "X coordinate in UPM units" },
        "y": { "type": "number", "description": "Y coordinate in UPM units" },
        "start": { "type": "boolean", "description": "Whether this node is the path start point", "default": false },
        "end": { "type": "boolean", "description": "Whether this node is the path end point", "default": false },
                    "control_mode": { "type": "string", "description": "Handle mode: corner (free), smooth (collinear), symmetric (mirrored)", "enum": ["corner", "smooth", "symmetric"], "default": "corner" },
        "control_1": { "$ref": "#/$defs/ControlHandle", "description": "Outgoing control handle (absolute position). Present = active." },
        "control_2": { "$ref": "#/$defs/ControlHandle", "description": "Incoming control handle (absolute position). Present = active." }
      },
      "additionalProperties": false
    },
    "ControlHandle": {
      "type": "object",
      "description": "A control handle position — presence in the vertex indicates it is active (no separate 'active' flag)",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "description": "Handle X position in UPM units" },
        "y": { "type": "number", "description": "Handle Y position in UPM units" }
      },
      "additionalProperties": false
    }
  }
}
